# ── SMTP ─────────────────────────────────────────────────────────────────────
# Gmail example:
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=465  SMTP_SECURE=true
#   SMTP_USER=you@gmail.com   SMTP_PASS=<app-password>
#
# SendGrid SMTP relay:
#   SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_SECURE=false
