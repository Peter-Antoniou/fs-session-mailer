# ── SMTP ─────────────────────────────────────────────────────────────────────
# Gmail example:
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false
#   SMTP_USER=you@gmail.com   SMTP_PASS=<app-password>
#
# SendGrid SMTP relay:
#   SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_SECURE=false
#   SMTP_USER=apikey             SMTP_PASS=<sendgrid-api-key>
#
# AWS SES SMTP:
#   SMTP_HOST=email-smtp.<region>.amazonaws.com  SMTP_PORT=587  SMTP_SECURE=false
#   SMTP_USER=<access-key-id>   SMTP_PASS=<ses-smtp-password>

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=peterantoniou@fullstory.com
SMTP_PASS=liyjivtkaxcaarir
EMAIL_FROM=Peter Antoniou

# "From" address in sent emails (defaults to SMTP_USER if omitted)
EMAIL_FROM="Fullstory Session Mailer <peterantoniou@fullstory.com>"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3849

# Optional: shared secret to verify X-FS-Signature header (HMAC-SHA256 hex).
# Leave blank to skip verification.
WEBHOOK_SECRET=
